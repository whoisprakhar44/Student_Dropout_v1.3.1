# Local dev: SQLite sample DB (created by app.py init_database)
SQLITE_DATABASE_PATH=../database/schema.db

# Server deploy: comment SQLITE_DATABASE_PATH and provide database credentials below
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_DATABASE=
# MYSQL_POOL_SIZE=20

# Impala MCP (disabled by default; enable on CDP server with kinit credentials)
# HIVE_MCP_ENABLED name preserved for backward compatibility — controls Impala executor
HIVE_MCP_ENABLED=false
HIVE_HOST=dl-dev-cl-fn01.datalake-dev.local
HIVE_PORT=21050
HIVE_DATABASE=curated_datamodels
