# ── Model ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:2b
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=512
OLLAMA_REASONING=false
# OLLAMA_REASONING: set to true to enable chain-of-thought thinking (recommended for reasoning models like deepseek-r1)
#                   set to false to disable (faster, lower memory, default for non-reasoning models)
RAG_TOP_K=4
MAX_VERIFY_LOOPS=10
MAX_LLM_CALLS=15

# ── MCP Server paths (override defaults in tools.py if needed) ────────────────
# RAG_SERVER_PATH=./servers/retrieval_mcp_server.py
# TOOL_SERVER_PATH=./servers/tool_mcp_server.py

# Impala MCP (disabled by default; enable on CDP server with kinit credentials)
# HIVE_MCP_ENABLED name preserved for backward compatibility — controls Impala executor
HIVE_MCP_ENABLED=false
HIVE_HOST=dl-dev-cl-fn01.datalake-dev.local
HIVE_PORT=21050
HIVE_DATABASE=curated_datamodels

# ── Impala / Kerberos Runtime Environment (required on CDP server) ────────────
# Set these before starting the app on the server (kinit must also be run).
# The values below match the verified CDP cluster configuration.
JAVA_HOME=/usr/lib/jvm/java-1.8.0-openjdk-1.8.0.492.b09-2.el9.x86_64/jre
HADOOP_HOME=/usr/local/hadoop-3.3.6
HADOOP_CONF_DIR=${HOME}/hadoop-configuration
# CLASSPATH is set automatically by hive_startup_check.py via: hadoop classpath --glob
